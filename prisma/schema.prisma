generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// ═══════════════════════════════════════════════════
/// User — 双角色用户模型（对应 WBS 2.3 双边权限配置）
/// ═══════════════════════════════════════════════════
model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  favoriteIds    String[]  @db.ObjectId // user can have many favorites
  role           String    @default("TOURIST") // TOURIST | GUIDE | ADMIN
  tokenBalance   Int       @default(10000) // virtual platform tokens (1 token = $1)

  accounts      Account[]
  listings      Listing[]
  reservations  Reservation[]
  reviews       Review[]
  notifications Notification[]
  transactions  Transaction[]
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  // create a relation between Account and User models using userId
  // we store the reference to the User model in the userId field
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // we need a unique combination of provider and providerAccountId
  @@unique([provider, providerAccountId])
}

/// ═══════════════════════════════════════════════════
/// Listing — 在地体验产品（原 Airbnb Listing 二次开发）
/// 对应 WBS 2.1 核心实体映射改造
/// ═══════════════════════════════════════════════════
model Listing {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String
  imageSrc      String
  createdAt     DateTime @default(now())
  category      String
  roomCount     Int
  bathroomCount Int
  guestCount    Int
  locationValue String
  userId        String   @db.ObjectId
  price         Int
  duration      Int      @default(4)   // 行程时长（小时）
  languages     String[] @default([])  // 支持语言列表
  meetingPoint  String?                // 集合地点
  timeSlot      String?                // MORNING | AFTERNOON | EVENING

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations Reservation[] // listing can have many reservations
  reviews      Review[]
}

/// ═══════════════════════════════════════════════════
/// Reservation — 预约订单（对应 WBS 2.2 订单流转模型）
/// 状态机：PENDING→ACCEPTED→IN_PROGRESS→COMPLETED
///                     ↘ CANCELLED（任意阶段可取消）
/// ═══════════════════════════════════════════════════
model Reservation {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  listingId     String    @db.ObjectId
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime  @default(now())
  totalPrice    Int
  status        String    @default("PENDING") // LOCKED | PENDING | ACCEPTED | IN_PROGRESS | COMPLETED | CANCELLED
  checkInTime   DateTime?
  checkOutTime  DateTime?
  holdExpiresAt DateTime? // set when status=LOCKED; auto-expires after 30 min

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  review  Review?
}

/// ═══════════════════════════════════════════════════
/// Review — 评价模型（DRE 指标数据来源）
/// DRE = 已处理差评数 / 总差评数 × 100%
/// ═══════════════════════════════════════════════════
model Review {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  userId        String    @db.ObjectId
  listingId     String    @db.ObjectId
  reservationId String    @unique @db.ObjectId // 一单一评
  rating        Int       // 1-5 星
  comment       String?
  isDefect      Boolean   @default(false) // rating <= 2 时为 true，用于 DRE 计算
  resolvedAt    DateTime?                  // 投诉被平台处理的时间
  createdAt     DateTime  @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing     Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  reservationId String   @db.ObjectId
  amount        Int      // negative = debit (payment), positive = credit (refund)
  type          String   // PAYMENT | REFUND
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  type          String   // NEW_BOOKING | RESERVATION_ACCEPTED | TOUR_STARTED | TOUR_COMPLETED | RESERVATION_CANCELLED
  message       String
  isRead        Boolean  @default(false)
  reservationId String?
  listingId     String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
